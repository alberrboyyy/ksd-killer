    <form method="POST" action="{{ route('login') }}">
      {{ csrfField() }}
      <div class="form-group">
        <label for="username">Nom d'utilisateur</label>
        <input type="text" id="username" name="username" class="form-input" placeholder="ex: albert" autocomplete="username" autofocus required />
      </div>
      <div class="form-group">
        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="password" class="form-input" placeholder="••••••" autocomplete="current-password" required />
      </div>
      <button type="submit" class="btn btn-primary">Se connecter</button>
    </form>
  </div>
